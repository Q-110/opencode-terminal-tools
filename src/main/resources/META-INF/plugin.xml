<idea-plugin>
    <id>io.github.q110.opencodeterminaltools</id>
    <name>OpenCode Terminal Tools</name>
    <vendor>zibo</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="io.github.q110.opencodeterminaltools.OpenCodeTerminalToolsSettings"/>
        <projectService serviceImplementation="io.github.q110.opencodeterminaltools.OpenCodeBridgeService"/>
        <applicationConfigurable
            parentId="tools"
            instance="io.github.q110.opencodeterminaltools.OpenCodeTerminalToolsConfigurable"
            id="io.github.q110.opencodeterminaltools.OpenCodeTerminalToolsConfigurable"
            displayName="OpenCode Terminal Tools"/>
        <consoleFilterProvider implementation="io.github.q110.opencodeterminaltools.OpenCodeTerminalToolsFilterProvider"/>
        <notificationGroup displayType="BALLOON" id="OpenCode Terminal Tools"/>
        <postStartupActivity implementation="io.github.q110.opencodeterminaltools.OpenCodeTerminalToolsMenuRegistrar"/>
    </extensions>

    <actions>
        <action
            id="OpenCodeTerminalTools.SendSelectionToOpenCode"
            class="io.github.q110.opencodeterminaltools.SendSelectionToOpenCodeAction"
            icon="/icons/send-selection.svg"
            text="Send Selection to OpenCode"
            description="Send the current editor selection to the marked OpenCode terminal"/>
        <action
            id="OpenCodeTerminalTools.SendPathToOpenCode"
            class="io.github.q110.opencodeterminaltools.SendPathToOpenCodeAction"
            icon="/icons/send-selection.svg"
            text="Send File Path to OpenCode"
            description="Send the selected repository-relative path to the marked OpenCode terminal"/>
        <action
            id="OpenCodeTerminalTools.MarkOpenCodeTerminal"
            class="io.github.q110.opencodeterminaltools.MarkOpenCodeTerminalAction"
            icon="/icons/send-selection.svg"
            text="Mark as OpenCode Terminal"
            description="Use this terminal tab as the OpenCode target">
            <add-to-group group-id="Terminal.OutputContextMenu" anchor="last"/>
            <add-to-group group-id="Terminal.PromptContextMenu" anchor="last"/>
            <add-to-group group-id="ToolWindowContextMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>

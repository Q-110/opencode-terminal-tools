<idea-plugin>
    <id>io.github.q110.aiterminaltools</id>
    <name>AI Terminal Tools</name>
    <vendor>zibo</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="terminal-frontend.xml">intellij.terminal.frontend</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="io.github.q110.aiterminaltools.settings.AiTerminalToolsSettings"/>
        <projectService serviceImplementation="io.github.q110.aiterminaltools.bridge.AiTerminalBridgeService"/>
        <projectService serviceImplementation="io.github.q110.aiterminaltools.bridge.AiTerminalDropService"/>
        <projectService serviceImplementation="io.github.q110.aiterminaltools.console.AiConsoleErrorInlayService"/>
        <applicationConfigurable
            parentId="tools"
            instance="io.github.q110.aiterminaltools.settings.AiTerminalToolsConfigurable"
            id="io.github.q110.aiterminaltools.settings.AiTerminalToolsConfigurable"
            displayName="AI Terminal Tools"/>
        <consoleFilterProvider implementation="io.github.q110.aiterminaltools.filter.AiTerminalToolsFilterProvider"/>
        <notificationGroup displayType="BALLOON" id="AI Terminal Tools"/>
        <postStartupActivity implementation="io.github.q110.aiterminaltools.bridge.AiTerminalToolsMenuRegistrar"/>
    </extensions>

    <actions>
        <action
            id="AiTerminalTools.SendSelectionToAiTerminal"
            class="io.github.q110.aiterminaltools.bridge.SendSelectionToAiTerminalAction"
            icon="/icons/send-selection.svg"
            text="发送选区到 AI Terminal"
            description="发送当前编辑器选区到激活的 AI 终端">
            <keyboard-shortcut keymap="$default" first-keystroke="control alt COMMA"/>
        </action>
        <action
            id="AiTerminalTools.SendPathToAiTerminal"
            class="io.github.q110.aiterminaltools.bridge.SendPathToAiTerminalAction"
            icon="/icons/send-selection.svg"
            text="发送文件路径到 AI Terminal"
            description="发送选中文件路径到激活的 AI 终端"/>
        <action
            id="AiTerminalTools.StartOpenCode"
            class="io.github.q110.aiterminaltools.bridge.StartOpenCodeAction"
            icon="/icons/opencode-official-action.png"
            text="启动 OpenCode"
            description="打开新终端并运行 opencode"/>
        <action
            id="AiTerminalTools.StartClaudeCode"
            class="io.github.q110.aiterminaltools.bridge.StartClaudeCodeAction"
            icon="/icons/claude-code-official-action.png"
            text="启动 Claude Code"
            description="打开新终端并运行 claude"/>
        <action
            id="AiTerminalTools.GenerateCommitMessage"
            class="io.github.q110.aiterminaltools.bridge.GenerateCommitMessageAction"
            icon="/icons/send-selection.svg"
            text="生成提交信息"
            description="根据已勾选文件生成简洁提交信息">
            <add-to-group group-id="ChangesView.CommitToolbar" anchor="after" relative-to-action="Vcs.MessageActionGroup"/>
        </action>
    </actions>
</idea-plugin>
